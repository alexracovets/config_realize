# --- Required for Shopify catalog/product data ---
SHOPIFY_ENABLED=true
SHOPIFY_STORE_DOMAIN=realize2-0.myshopify.com
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# Optional: use Admin API instead of Storefront API
# SHOPIFY_ADMIN_ACCESS_TOKEN=
# SHOPIFY_API_MODE=storefront

SHOPIFY_API_VERSION=2025-01

# Optional: override home collection order (comma-separated handles)
# SHOPIFY_HOME_COLLECTION_HANDLES=completo-gara-calcio,completo-gara-pallavolo,completo-gara-basket,completo

# --- Iframe embed (Shopify theme) ---
# Leave EMPTY. Do not use wildcards like https://*.myshopify.com — browsers ignore them.
# These origins are added automatically by middleware:
#   https://admin.shopify.com
#   https://online-store-web.shopifyapps.com  (Theme Editor preview)
#   https://{SHOPIFY_STORE_DOMAIN}
#   https://{shop} from ?shop= query param
# Only set extra custom domains here, e.g. https://www.your-custom-domain.com
SHOPIFY_FRAME_ANCESTORS=
